# Copy this file to .streamlit/secrets.toml and fill in your values.
# secrets.toml is gitignored — never commit real credentials.

# Sentry error monitoring (https://sentry.io — free tier available)
SENTRY_DSN = ""

# Blue rate auto-fetch — point this at any JSON endpoint that returns
# the current BOB/USD parallel rate. The app supports these response shapes:
#   {"blue": {"sell": 9.20}}
#   {"blue": {"value": 9.20}}
#   {"blue": 9.20}
#   {"rate": 9.20}
#   {"value": 9.20}
BLUE_RATE_API_URL = ""

# Optional bearer token if your blue rate API requires auth
BLUE_RATE_API_KEY = ""
